# =============================================================================
# .env.prod.example — 프로덕션 환경변수 템플릿
# -----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 .env.prod 로 복사
#        cp .env.prod.example .env.prod
#   2) 각 값을 실제 시크릿으로 교체
#   3) 파일 권한을 600 으로 제한 (운영자만 읽기/쓰기)
#        chmod 600 .env.prod
#   4) .env.prod 는 절대 커밋 금지 (.gitignore 에 등록됨)
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (내부 전용 — 외부 포트 노출 안 함)
# ---------------------------------------------------------------------------
POSTGRES_DB=signal_db
POSTGRES_USER=signal
# 16자 이상 랜덤 문자열 권장 (예: `openssl rand -base64 24`)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---------------------------------------------------------------------------
# Spring Boot
# ---------------------------------------------------------------------------
# 활성 프로파일 (기본 prod). local/dev 로 바꾸지 말 것.
SPRING_PROFILES_ACTIVE=prod

# 관리자 API Key — /api/admin/* 엔드포인트 인증에 사용
# 32자 이상 랜덤 (예: `openssl rand -hex 32`)
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY

# ---------------------------------------------------------------------------
# Telegram Bot (시그널 알림)
# ---------------------------------------------------------------------------
# BotFather 로 발급받은 토큰
TELEGRAM_BOT_TOKEN=CHANGE_ME_BOT_TOKEN
# 알림 수신 채팅/채널 ID (숫자, 채널이면 - 접두사)
TELEGRAM_CHAT_ID=CHANGE_ME_CHAT_ID

# ---------------------------------------------------------------------------
# KRX Open API (공매도 데이터 수집)
# ---------------------------------------------------------------------------
# data.krx.co.kr 발급 Auth Key
KRX_AUTH_KEY=CHANGE_ME_KRX_AUTH_KEY

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
# 브라우저에서 보이는 API base path. 같은 도메인에서 역프록시 쓸 경우 "/api" 유지.
# 별도 백엔드 도메인이 있으면 "https://api.example.com" 등으로 교체.
NEXT_PUBLIC_API_BASE_URL=/api

# 호스트에서 프론트엔드에 매핑할 포트 (기본 3000, 80/443 쓰려면 역프록시 권장)
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# 이미지 태그 (CI 에서 SHA 주입. 수동 배포면 latest 또는 버전태그)
# ---------------------------------------------------------------------------
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Caddy / TLS
# ---------------------------------------------------------------------------
# 실서비스 도메인 (없으면 localhost 로 두면 Caddy 가 내부 CA 로 self-signed)
DOMAIN=localhost
# Let's Encrypt ACME 계정 이메일 (실도메인일 때만 의미)
ACME_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# DB 접속 별칭 (Spring Boot application.yml 에서 참조)
# ---------------------------------------------------------------------------
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

# ============================================================================
# Python 이전(§11 / docs/migration/java-to-python-plan.md) 신규 변수
# Phase 10~13 진입 시점부터 사용. 지금 값을 채워두면 이후 단계에서 재사용됨.
# ============================================================================

# ---------------------------------------------------------------------------
# DART OpenAPI (금융감독원 전자공시)
# 발급: https://opendart.fss.or.kr  (인증키 신청 → 이메일 인증)
# ---------------------------------------------------------------------------
DART_API_KEY=CHANGE_ME_DART_API_KEY

# ---------------------------------------------------------------------------
# OpenAI (GPT-5.4 계열 — 수집/분석/리패키징)
# 발급: https://platform.openai.com/api-keys  (결제수단 등록 필수)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY

# ---------------------------------------------------------------------------
# 한국투자증권(KIS) 모의투자
# 발급: https://apiportal.koreainvestment.com  (실계좌 + 모의투자 참가 선행)
# 베이스 URL: https://openapivts.koreainvestment.com:29443 (코드에 하드코드, 실거래 차단)
# ---------------------------------------------------------------------------
KIS_APP_KEY_MOCK=CHANGE_ME_KIS_APP_KEY_MOCK
KIS_APP_SECRET_MOCK=CHANGE_ME_KIS_APP_SECRET_MOCK
KIS_ACCOUNT_NO_MOCK=CHANGE_ME_KIS_ACCOUNT_NO_MOCK

# ---------------------------------------------------------------------------
# Plan A 전환용(옵션, 예산 확정 시)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# PPLX_API_KEY=
