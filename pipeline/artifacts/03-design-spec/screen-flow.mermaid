%% 공매도 커버링 시그널 탐지 시스템 — 화면 흐름도

graph TD
    START((시작)) --> NAV[글로벌 네비게이션]

    NAV --> P1[P1: 대시보드<br/>오늘의 시그널 리스트]
    NAV --> P3[P3: 백테스팅<br/>적중률/수익률 통계]
    NAV --> P4[P4: 시장 동향<br/>v1.1 Coming Soon]
    NAV --> P5[P5: 설정<br/>v1.1 Coming Soon]

    P1 -->|시그널 카드 클릭| P2[P2: 종목 상세<br/>차트 + 스코어 근거]
    P2 -->|뒤로| P1

    P1 -->|탭 필터| P1_FILTER{시그널 필터}
    P1_FILTER -->|전체| P1
    P1_FILTER -->|급감| P1
    P1_FILTER -->|추세전환| P1
    P1_FILTER -->|숏스퀴즈| P1

    P2 -->|기간 선택| P2_PERIOD{기간 변경}
    P2_PERIOD -->|1개월| P2
    P2_PERIOD -->|3개월| P2
    P2_PERIOD -->|6개월| P2
    P2_PERIOD -->|1년| P2

    %% 텔레그램 알림 흐름
    TG((텔레그램 알림)) -->|링크 클릭| P1
    TG -->|종목 링크| P2

    %% 에러 흐름
    P1 -->|API 에러| ERR_P1[에러 상태<br/>재시도 버튼]
    ERR_P1 -->|재시도| P1
    P2 -->|종목 없음| ERR_P2[404 상태<br/>대시보드 이동]
    ERR_P2 --> P1

    %% 빈 상태
    P1 -->|시그널 0건| EMPTY_P1[빈 상태<br/>내일 확인 안내]
    P3 -->|미실행| EMPTY_P3[빈 상태<br/>자동 실행 안내]

    style P1 fill:#3182F6,color:#fff
    style P2 fill:#3182F6,color:#fff
    style P3 fill:#3182F6,color:#fff
    style P4 fill:#ccc,color:#666
    style P5 fill:#ccc,color:#666
    style TG fill:#26A5E4,color:#fff
