# backend_kiwoom 환경변수 템플릿
# 운영 배포 시 .env 또는 시크릿 매니저로 주입.

APP_NAME=ted-kiwoom-backend
APP_ENV=local
PORT=8001
LOG_LEVEL=INFO

# Database (kiwoom 스키마는 자동 생성됨)
DATABASE_URL=postgresql+asyncpg://kiwoom:kiwoom@localhost:5432/kiwoom_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Kiwoom API
KIWOOM_BASE_URL_PROD=https://api.kiwoom.com
KIWOOM_BASE_URL_MOCK=https://mockapi.kiwoom.com
KIWOOM_DEFAULT_ENV=mock
KIWOOM_REQUEST_TIMEOUT_SECONDS=15.0
KIWOOM_MIN_REQUEST_INTERVAL_SECONDS=0.25
KIWOOM_CONCURRENT_REQUESTS=4

# 자격증명 마스터키 — Fernet.generate_key() 출력 (32B base64)
# 운영 환경 빈 값이면 cipher 초기화 시 즉시 fail-fast.
KIWOOM_CREDENTIAL_MASTER_KEY=

# NXT 수집 토글 — False 면 KRX 만 수집
NXT_COLLECTION_ENABLED=true

# 백필
BACKFILL_MAX_DAYS=1095
BACKFILL_CONCURRENCY=2

# Admin (X-API-Key 헤더 검증)
ADMIN_API_KEY=

# 스케줄러 (운영만 true)
SCHEDULER_ENABLED=false
