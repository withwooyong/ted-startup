# ==============================================================================
# src/backend_py/.env.example — Python 백엔드 로컬 개발용 템플릿
# 실제 사용 파일명: .env (로컬) 또는 .env.prod (운영, 루트에 위치)
# 값은 반드시 각자 채우고 커밋하지 말 것
# ==============================================================================

# ---- 앱 기본 ----
APP_NAME=ted-signal-backend
APP_ENV=local                     # local | dev | prod
PORT=8000

# ---- CORS 화이트리스트 (콤마 구분 또는 JSON 배열) ----
# 비어있으면 CORS 미들웨어는 비활성. "*" 는 credentials=true와 함께 금지됨.
# 예) CORS_ALLOW_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_ORIGINS=[]

# ==============================================================================
# 외부 연동 — Phase 진입 시 채우기
# ==============================================================================

# Phase 13: DART OpenAPI
DART_API_KEY=

# Phase 13: OpenAI
OPENAI_API_KEY=

# Phase 11: KIS 모의투자
KIS_APP_KEY_MOCK=
KIS_APP_SECRET_MOCK=
KIS_ACCOUNT_NO_MOCK=
